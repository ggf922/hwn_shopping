# ============================================================================
# Supabase 마이그레이션용 환경변수 (예시)
# ============================================================================
# 사용법:
#   1. 이 파일을 .env.migration 으로 복사
#      cp .env.migration.example .env.migration
#   2. 실제 값으로 채우기
#   3. .env.migration 은 .gitignore에 포함되어 있으므로 절대 커밋되지 않음
# ============================================================================

# Supabase 프로젝트 URL
# 위치: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Supabase Service Role Key (⚠️ 절대 외부 공개 금지!)
# 위치: Supabase Dashboard → Project Settings → API → Project API keys → service_role
# 용도: 데이터 이식 시 RLS를 우회하기 위해 필요
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
